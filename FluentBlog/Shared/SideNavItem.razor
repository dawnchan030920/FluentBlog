@inject NavigationManager NavigationManager
@inject MenuService MenuService
@inject UriValidator UriValidator

<FluentOption Value="@ItemData?.Tag" Selected="@UriValidator.IsActive(ItemData)">
	@*<FluentIcon Name="@ItemData?.Icon" Filled=false Size="@IconSize.Size20"></FluentIcon>*@
	@ItemData?.Tag
</FluentOption>

@code {
	[Parameter]
	public MenuItem? ItemData { get; set; }

	protected override void OnInitialized()
	{
		NavigationManager.LocationChanged += (s, e) => StateHasChanged();
	}
}